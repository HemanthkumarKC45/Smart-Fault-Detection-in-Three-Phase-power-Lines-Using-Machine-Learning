import pickle
import pandas as pd
import numpy as np
from flask import Flask, render_template, jsonify
from datetime import datetime, timedelta


app = Flask(_name_, template_folder='templates')


MODEL_PATH = 'fault_detector.pkl'
DATA_PATH = 'historical_data.csv'


model = None
data_df = None
data_index = 0
MAX_INDEX = 0



def load_resources():
    """Loads the ML model and the historical data frame."""
    global model, data_df, MAX_INDEX
    
    try:
        with open(MODEL_PATH, 'rb') as f:
            model = pickle.load(f)
        print(f"Successfully loaded model from {MODEL_PATH}")
    except Exception as e:
        print(f"ERROR: Could not load model file. Ensure {MODEL_PATH} exists.")
        print(f"Exception: {e}")
        model = None
        
    
    try:
        data_df = pd.read_csv(DATA_PATH)
       
        required_cols = ['Voltage', 'Current', 'Temp', 'Humidity', 'Timestamp']
        if not all(col in data_df.columns for col in required_cols):
             raise ValueError(f"Data is missing required columns: {required_cols}")

        MAX_INDEX = len(data_df) - 1
        print(f"Successfully loaded {len(data_df)} historical records.")
    except Exception as e:
        print(f"ERROR: Could not load data file. Ensure {DATA_PATH} exists.")
        print(f"Exception: {e}")
        data_df = None


load_resources()




def get_prediction_label(prediction):
    """Converts the numerical prediction (0, 1, 2) to a readable string."""
    if prediction == 0:
        return "Normal Operations"
    elif prediction == 1:
        return "High_Load_Anomaly"
    elif prediction == 2:
        return "Line_Fault"
    else:
        return "Unknown Status"




@app.route('/')
def index():
    """Renders the main dashboard HTML template."""
    return render_template('dashboard.html')

@app.route('/live_data')
def live_data():
    """
    Cycles through the historical data, makes a prediction on the current row, 
    and returns the result as JSON.
    """
    global data_index

   
    if data_df is None or model is None:
        return jsonify({
            "voltage": 0.0,
            "current": 0.0,
            "temp": 0.0,
            "humidity": 0.0,
            "status": "NO DATA / MODEL ERROR",
            "timestamp": "N/A"
        })

    
    try:
        current_data = data_df.iloc[data_index].to_dict()
        
       
        features = np.array([[
            current_data['Voltage'], 
            current_data['Current'], 
            current_data['Temp'], 
            current_data['Humidity']
        ]])
        
        
        prediction = model.predict(features)[0]
        status_label = get_prediction_label(prediction)

       
        response = {
            "voltage": float(current_data['Voltage']),
            "current": float(current_data['Current']),
            "temp": float(current_data['Temp']),
            "humidity": float(current_data['Humidity']),
            "status": status_label,
            "timestamp": current_data['Timestamp'] 
        }

        
        data_index = (data_index + 1) % (MAX_INDEX + 1)
        
        return jsonify(response)
        
    except Exception as e:
        print(f"ERROR processing data point at index {data_index}: {e}")
        
        data_index = 0 
        return jsonify({
            "voltage": 0.0,
            "current": 0.0,
            "temp": 0.0,
            "humidity": 0.0,
            "status": "DATA PROCESSING ERROR",
            "timestamp": "N/A"
        })



if _name_ == '_main_':
    
    app.run(debug=True)
